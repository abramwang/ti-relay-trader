      { "name": "price", "label": "price", "source": "body", "type": "number", "required": true, "defaultValue": "9.67" },
      { "name": "qty", "label": "qty", "source": "body", "type": "integer", "required": true, "defaultValue": "100" },
      { "name": "idempotency_key", "label": "idempotency_key", "source": "body", "defaultValue": "relay-api-console-demo" }
    ]
